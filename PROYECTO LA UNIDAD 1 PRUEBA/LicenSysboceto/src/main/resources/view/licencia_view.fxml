<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  ═══════════════════════════════════════════════════════
   PAQUETE: view (resources)
   ARCHIVO: licencia_view.fxml
  ═══════════════════════════════════════════════════════
  Vista principal del sistema CRUD de Licencias.
  Diseño en dos zonas:
    • LEFT  → formulario de entrada de datos
    • RIGHT → tabla con registros y búsqueda
-->
<BorderPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="pe.edu.upeu.controller.LicenciaController"
        prefWidth="1050" prefHeight="680"
        style="-fx-background-color: #f0f2f5;">

    <!-- ═══════════════════════ CABECERA ═══════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #1a237e, #3949ab);">

            <!-- Título y estadísticas -->
            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-padding: 16 24 16 24;">

                <Label text="🪪" style="-fx-font-size: 30;"/>
                <VBox spacing="2">
                    <Label text="Sistema de Gestión de Licencias de Conducir"
                           style="-fx-text-fill: white; -fx-font-size: 18;
                                  -fx-font-weight: bold;"/>
                    <Label text="Registro · Edición · Eliminación · Vigencia automática"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Tarjetas de estadísticas -->
                <HBox spacing="10" alignment="CENTER">
                    <!-- Total -->
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color: rgba(255,255,255,0.12);
                                 -fx-background-radius: 8; -fx-padding: 8 16;">
                        <Label fx:id="lblTotal" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold;
                                      -fx-text-fill: white;"/>
                        <Label text="Total"
                               style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                    <!-- Vigentes -->
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color: rgba(255,255,255,0.12);
                                 -fx-background-radius: 8; -fx-padding: 8 16;">
                        <Label fx:id="lblVigentes" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold;
                                      -fx-text-fill: #a5d6a7;"/>
                        <Label text="Vigentes"
                               style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                    <!-- Vencidas -->
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color: rgba(255,255,255,0.12);
                                 -fx-background-radius: 8; -fx-padding: 8 16;">
                        <Label fx:id="lblVencidas" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold;
                                      -fx-text-fill: #ef9a9a;"/>
                        <Label text="Vencidas"
                               style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════ CONTENIDO PRINCIPAL ════════════════════ -->
    <center>
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            <!-- ────────────────────────────────────────────────────────
                 PANEL IZQUIERDO: Formulario de datos
                 ──────────────────────────────────────────────────────── -->
            <VBox spacing="14" prefWidth="310" minWidth="290"
                  style="-fx-background-color: white;
                         -fx-border-color: #e0e0e0;
                         -fx-border-width: 0 1 0 0;
                         -fx-padding: 20 20 20 20;">

                <!-- Título del formulario -->
                <Label text="📋 Datos de la Licencia"
                       style="-fx-font-size: 14; -fx-font-weight: bold;
                              -fx-text-fill: #1a237e;"/>

                <Separator/>

                <!-- Nombre del Titular -->
                <VBox spacing="4">
                    <Label text="👤 Nombre del Titular *"
                           style="-fx-font-weight: bold; -fx-font-size: 12;
                                  -fx-text-fill: #424242;"/>
                    <TextField fx:id="txtNombre"
                               promptText="Ej: Juan Pérez García"
                               style="-fx-background-radius: 6;
                                      -fx-border-color: #c5cae9;
                                      -fx-border-radius: 6;
                                      -fx-padding: 8 10;"/>
                </VBox>

                <!-- Número de Licencia -->
                <VBox spacing="4">
                    <Label text="🪪 Número de Licencia *"
                           style="-fx-font-weight: bold; -fx-font-size: 12;
                                  -fx-text-fill: #424242;"/>
                    <TextField fx:id="txtNumero"
                               promptText="Ej: LIC-B-001"
                               style="-fx-background-radius: 6;
                                      -fx-border-color: #c5cae9;
                                      -fx-border-radius: 6;
                                      -fx-padding: 8 10;
                                      -fx-font-family: monospace;"/>
                    <Label text="⚠ El número es único e inmutable en edición."
                           style="-fx-font-size: 10; -fx-text-fill: #9e9e9e;
                                  -fx-font-style: italic;"/>
                </VBox>

                <!-- Tipo de Licencia -->
                <VBox spacing="4">
                    <Label text="🚗 Tipo de Licencia *"
                           style="-fx-font-weight: bold; -fx-font-size: 12;
                                  -fx-text-fill: #424242;"/>
                    <ComboBox fx:id="cboTipo"
                              maxWidth="Infinity"
                              style="-fx-background-radius: 6;
                                     -fx-border-color: #c5cae9;
                                     -fx-border-radius: 6;"/>
                    <HBox spacing="8">
                        <Label text="A: Moto"
                               style="-fx-font-size: 10; -fx-text-fill: #e65100;"/>
                        <Label text="B: Auto"
                               style="-fx-font-size: 10; -fx-text-fill: #0d47a1;"/>
                        <Label text="C: Pesados"
                               style="-fx-font-size: 10; -fx-text-fill: #4a148c;"/>
                    </HBox>
                </VBox>

                <!-- Fecha de Expedición -->
                <VBox spacing="4">
                    <Label text="📅 Fecha de Expedición *"
                           style="-fx-font-weight: bold; -fx-font-size: 12;
                                  -fx-text-fill: #424242;"/>
                    <DatePicker fx:id="dpExpedicion" maxWidth="Infinity"
                                promptText="dd/MM/yyyy"/>
                </VBox>

                <!-- Fecha de Vencimiento -->
                <VBox spacing="4">
                    <Label text="⏰ Fecha de Vencimiento *"
                           style="-fx-font-weight: bold; -fx-font-size: 12;
                                  -fx-text-fill: #424242;"/>
                    <DatePicker fx:id="dpVencimiento" maxWidth="Infinity"
                                promptText="dd/MM/yyyy"/>
                </VBox>

                <!-- Preview del Estatus (calculado automáticamente) -->
                <VBox spacing="4"
                      style="-fx-background-color: #f8f9fa;
                             -fx-background-radius: 8;
                             -fx-border-color: #e0e0e0;
                             -fx-border-radius: 8;
                             -fx-padding: 10 12;">
                    <Label text="📊 Estatus calculado automáticamente:"
                           style="-fx-font-size: 11; -fx-text-fill: #757575;"/>
                    <Label fx:id="lblEstatus"
                           text="— Sin fecha seleccionada —"
                           style="-fx-font-size: 14; -fx-font-weight: bold;
                                  -fx-text-fill: #9e9e9e;"/>
                    <Label fx:id="lblDiasInfo" text=""
                           style="-fx-font-size: 11; -fx-text-fill: #9e9e9e;
                                  -fx-font-style: italic;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Botones de acción -->
                <VBox spacing="8">
                    <Button text="➕  Agregar Licencia"
                            onAction="#onAgregar"
                            maxWidth="Infinity" prefHeight="38"
                            style="-fx-background-color: #1a237e;
                                   -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-font-size: 13;"/>

                    <Button text="💾  Guardar Cambios"
                            onAction="#onEditar"
                            maxWidth="Infinity" prefHeight="36"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #1a237e; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #1a237e; -fx-border-radius: 8;
                                   -fx-border-width: 1.5;"/>

                    <Button text="🗑️  Eliminar Seleccionada"
                            onAction="#onEliminar"
                            maxWidth="Infinity" prefHeight="36"
                            style="-fx-background-color: #fce4ec;
                                   -fx-text-fill: #b71c1c; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button text="✖  Limpiar Formulario"
                            onAction="#onLimpiar"
                            maxWidth="Infinity" prefHeight="32"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #757575;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #bdbdbd; -fx-border-radius: 8;
                                   -fx-border-width: 1; -fx-font-size: 12;"/>
                </VBox>
            </VBox>

            <!-- ────────────────────────────────────────────────────────
                 PANEL DERECHO: Búsqueda + Tabla
                 ──────────────────────────────────────────────────────── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS">

                <!-- Barra de búsqueda -->
                <HBox spacing="8" alignment="CENTER_LEFT"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 0 0 1 0;
                             -fx-padding: 12 16;">

                    <Label text="🔍" style="-fx-font-size: 15;"/>
                    <TextField fx:id="txtBuscar"
                               promptText="Buscar por nombre o número..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 20;
                                      -fx-border-color: #c5cae9;
                                      -fx-border-radius: 20;
                                      -fx-padding: 7 14; -fx-font-size: 13;"/>

                    <Button text="Buscar"
                            onAction="#onBuscar"
                            prefHeight="34"
                            style="-fx-background-color: #3949ab;
                                   -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-padding: 6 16;"/>

                    <Button text="Ver todas"
                            onAction="#onVerTodas"
                            prefHeight="34"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #5c6bc0;
                                   -fx-border-color: #c5cae9; -fx-border-radius: 8;
                                   -fx-border-width: 1; -fx-cursor: hand;
                                   -fx-padding: 5 14;"/>
                </HBox>

                <!-- Tabla de licencias -->
                <TableView fx:id="tablaLicencias"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white;">
                    <columns>
                        <TableColumn fx:id="colId"
                                     text="ID"
                                     prefWidth="50" minWidth="40"/>

                        <TableColumn fx:id="colNombre"
                                     text="Nombre del Titular"
                                     prefWidth="195" minWidth="140"/>

                        <TableColumn fx:id="colNumero"
                                     text="N° Licencia"
                                     prefWidth="120" minWidth="90"/>

                        <TableColumn fx:id="colTipo"
                                     text="Tipo"
                                     prefWidth="65" minWidth="55"/>

                        <TableColumn fx:id="colExpedicion"
                                     text="Expedición"
                                     prefWidth="100" minWidth="90"/>

                        <TableColumn fx:id="colVencimiento"
                                     text="Vencimiento"
                                     prefWidth="105" minWidth="90"/>

                        <TableColumn fx:id="colEstatus"
                                     text="Estatus"
                                     prefWidth="110" minWidth="90"/>

                        <TableColumn fx:id="colAcciones"
                                     text="Acciones"
                                     prefWidth="115" minWidth="100"
                                     sortable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

            </VBox>
        </HBox>
    </center>

    <!-- ═══════════════════════ PIE DE PÁGINA ═════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #e8eaf6;
                     -fx-border-color: #c5cae9;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 7 20;">
            <Label text="Sistema CRUD · Licencias de Conducir  ·  "
                   style="-fx-font-size: 10.5; -fx-text-fill: #5c6bc0;"/>
            <Label text="Arquitectura MVC: model · dao · service · controller · util"
                   style="-fx-font-size: 10.5; -fx-text-fill: #9fa8da;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Vigencia calculada automáticamente con java.time.LocalDate"
                   style="-fx-font-size: 10; -fx-text-fill: #bdbdbd;"/>
        </HBox>
    </bottom>

</BorderPane>

